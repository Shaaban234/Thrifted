# Copy to .env.local (git-ignored) and fill in. NEVER commit real secrets.

# Your Neon connection string (from the Neon dashboard "Connect" dialog).
# Use the POOLED connection string. Keep the password secret.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Secret used to sign auth tokens. Generate a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
